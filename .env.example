# Port to listen on (default: 3000)
PORT=3131

# Log incoming payloads (default: false)
DEBUG=false

# Optional: path to config file (default: ./config.json)
# CONFIG_PATH=/etc/dokploy-relay/config.json

# Optional: pass config as JSON string instead of a file (useful for Docker/Dokploy)
# CONFIG={"routes":[{"name":"my-api","path":"/webhook/my-api","slackWebhookUrl":"YOUR_SLACK_WEBHOOK_URL_HERE"}]}
